#!/usr/bin/env bash
# ============================================================
# XsltCraft — pre-commit hook
# Hızlı kontroller: her commit öncesi çalışır (~10 sn)
# ============================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

PASS="${GREEN}✓${NC}"
FAIL="${RED}✗${NC}"
WARN="${YELLOW}⚠${NC}"

error=0

echo -e "\n${CYAN}╔══════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║       XsltCraft pre-commit kontrol       ║${NC}"
echo -e "${CYAN}╚══════════════════════════════════════════╝${NC}\n"

# ── Staged dosyaları al ────────────────────────────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [[ -z "$STAGED" ]]; then
  echo -e "${WARN}  Staged dosya bulunamadı, kontrol atlandı."
  exit 0
fi

# ────────────────────────────────────────────────────────────
# 1. HASSAS DOSYA KONTROLÜ
# appsettings.Development.json gitignore'da olmalı, ama
# yanlışlıkla force-add edilirse yakala.
# ────────────────────────────────────────────────────────────
echo -e "${CYAN}[1/6] Hassas dosya kontrolü...${NC}"
SENSITIVE_FILES=(
  "appsettings.Development.json"
  "secrets.json"
  ".env"
  ".env.local"
  ".env.production"
  ".env.development"
)
for f in "${SENSITIVE_FILES[@]}"; do
  if echo "$STAGED" | grep -q "$f"; then
    echo -e "  ${FAIL} HATA: '${f}' commit'e eklenmemeli! Şifre/token içerebilir."
    echo -e "       Çıkarmak için: git reset HEAD '${f}'"
    error=1
  fi
done
[[ $error -eq 0 ]] && echo -e "  ${PASS} Hassas dosya yok."

# ────────────────────────────────────────────────────────────
# 2. SECRET / KREDENSİYEL TARAMASI
# Staged dosyaların içeriğini tara.
# ────────────────────────────────────────────────────────────
echo -e "${CYAN}[2/6] Secret taraması...${NC}"

SECRET_PATTERNS=(
  # JWT secret değerleri (örnek veya varsayılan olanları dışla)
  "SecretKey.*:.*\"[A-Za-z0-9+/]{20,}"
  # Google OAuth credentials
  "GOCSPX-[A-Za-z0-9_-]{20,}"
  "AIza[0-9A-Za-z_-]{35}"
  # Generic high-entropy secrets
  "clientsecret.*=.*['\"][A-Za-z0-9+/]{20,}"
  # Postgres connection strings with real passwords (not placeholder)
  "Password=[^;\"']{8,}"
  # Private keys
  "BEGIN (RSA|EC|OPENSSH) PRIVATE KEY"
  # AWS keys
  "AKIA[0-9A-Z]{16}"
)

secret_found=0
while IFS= read -r file; do
  # Binary ve dökümantasyon dosyalarını atla
  if file "$file" 2>/dev/null | grep -q "binary"; then
    continue
  fi
  if echo "$file" | grep -qE "\.(md|txt|rst)$"; then
    continue
  fi
  # CI workflow dosyaları test kimlik bilgisi içerebilir — atla
  if echo "$file" | grep -qE "^\.github/workflows/"; then
    continue
  fi
  # Sadece metin dosyalarını tara
  for pattern in "${SECRET_PATTERNS[@]}"; do
    matches=$(git diff --cached -U0 -- "$file" 2>/dev/null \
      | grep "^+" \
      | grep -iE "$pattern" \
      | grep -v "^+++" \
      | grep -v "change-me" \
      | grep -v "your-secret" \
      | grep -v "example" \
      | grep -v "placeholder" || true)
    if [[ -n "$matches" ]]; then
      echo -e "  ${FAIL} HATA: '$file' içinde olası secret tespit edildi:"
      echo "$matches" | head -3 | sed 's/^/       /'
      secret_found=1
      error=1
    fi
  done
done <<< "$STAGED"

[[ $secret_found -eq 0 ]] && echo -e "  ${PASS} Secret bulunamadı."

# ────────────────────────────────────────────────────────────
# 3. XSLT DOSYASI KONTROLÜ
# .xslt dosyaları storage/'a yazılır, repoya eklenmez.
# ────────────────────────────────────────────────────────────
echo -e "${CYAN}[3/6] XSLT dosya kontrolü...${NC}"
XSLT_STAGED=$(echo "$STAGED" | grep -E "\.xslt$" || true)
if [[ -n "$XSLT_STAGED" ]]; then
  echo -e "  ${FAIL} HATA: .xslt dosyaları repoya eklenmez (PRD §17 — storage stratejisi):"
  echo "$XSLT_STAGED" | sed 's/^/       /'
  error=1
else
  echo -e "  ${PASS} XSLT dosyası yok."
fi

# ────────────────────────────────────────────────────────────
# 4. CONSOLE.LOG KONTROLÜ (frontend)
# Production'a console.log kalmamalı.
# ────────────────────────────────────────────────────────────
echo -e "${CYAN}[4/6] console.log kontrolü (frontend)...${NC}"
FRONTEND_STAGED=$(echo "$STAGED" | grep -E "^frontend/.*\.(ts|tsx|js|jsx)$" || true)
console_found=0
if [[ -n "$FRONTEND_STAGED" ]]; then
  while IFS= read -r file; do
    matches=$(git diff --cached -U0 -- "$file" 2>/dev/null \
      | grep "^+" \
      | grep -v "^+++" \
      | grep -E "console\.(log|warn|error|debug|info)" \
      | grep -v "// " \
      | grep -v "\* " || true)
    if [[ -n "$matches" ]]; then
      echo -e "  ${WARN}  UYARI: '$file' içinde console.log bulundu:"
      echo "$matches" | head -3 | sed 's/^/       /'
      console_found=1
    fi
  done <<< "$FRONTEND_STAGED"
fi
[[ $console_found -eq 0 ]] && echo -e "  ${PASS} console.log yok."

# ────────────────────────────────────────────────────────────
# 5. HARDCODED URL KONTROLÜ (frontend)
# localhost URL'leri production koda karışmamalı.
# ────────────────────────────────────────────────────────────
echo -e "${CYAN}[5/6] Hardcoded URL kontrolü...${NC}"
url_found=0
if [[ -n "$FRONTEND_STAGED" ]]; then
  while IFS= read -r file; do
    # apiService.ts ve vite.config.ts gibi config dosyalarını atla
    if echo "$file" | grep -qE "(apiService|vite\.config|\.env)"; then
      continue
    fi
    matches=$(git diff --cached -U0 -- "$file" 2>/dev/null \
      | grep "^+" \
      | grep -v "^+++" \
      | grep -E "http://localhost:[0-9]+" \
      | grep -v "// " || true)
    if [[ -n "$matches" ]]; then
      echo -e "  ${WARN}  UYARI: '$file' içinde hardcoded localhost URL var:"
      echo "$matches" | head -2 | sed 's/^/       /'
      url_found=1
    fi
  done <<< "$FRONTEND_STAGED"
fi
[[ $url_found -eq 0 ]] && echo -e "  ${PASS} Hardcoded URL yok."

# ────────────────────────────────────────────────────────────
# 6. BRANCH İSMİ KONTROLÜ
# Sadece izin verilen pattern'larda commit yapılabilir.
# ────────────────────────────────────────────────────────────
echo -e "${CYAN}[6/6] Branch ismi kontrolü...${NC}"
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
ALLOWED_BRANCH_PATTERN="^(main|develop|feature/faz-[0-9]+-[a-z0-9-]+|fix/[a-z0-9-]+|hotfix/[a-z0-9-]+|chore/[a-z0-9-]+|docs/[a-z0-9-]+)$"

if [[ "$BRANCH" =~ $ALLOWED_BRANCH_PATTERN ]]; then
  echo -e "  ${PASS} Branch ismi geçerli: '${BRANCH}'"
else
  echo -e "  ${WARN}  UYARI: Branch ismi '${BRANCH}' konvansiyona uymayabilir."
  echo -e "       Beklenen format: feature/faz-N-konu | fix/konu | hotfix/konu | chore/konu"
fi

# ────────────────────────────────────────────────────────────
# SONUÇ
# ────────────────────────────────────────────────────────────
echo ""
if [[ $error -ne 0 ]]; then
  echo -e "${RED}╔══════════════════════════════════════════╗${NC}"
  echo -e "${RED}║   Commit ENGELLENDİ — hataları düzelt   ║${NC}"
  echo -e "${RED}╚══════════════════════════════════════════╝${NC}\n"
  exit 1
else
  echo -e "${GREEN}╔══════════════════════════════════════════╗${NC}"
  echo -e "${GREEN}║        Tüm kontroller başarılı ✓         ║${NC}"
  echo -e "${GREEN}╚══════════════════════════════════════════╝${NC}\n"
  exit 0
fi
