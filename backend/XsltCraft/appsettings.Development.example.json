{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=xsltcraft;Username=xsltcraft;Password=<.env'deki POSTGRES_PASSWORD>"
  },
  "Jwt": {
    "SecretKey": "<en az 32 karakter rastgele string — örn: openssl rand -hex 32>",
    "Issuer": "xsltcraft",
    "Audience": "xsltcraft-client",
    "AccessTokenExpiryMinutes": 15
  },
  "Google": {
    "ClientId": "<Google Cloud Console'dan>",
    "ClientSecret": "<Google Cloud Console'dan>"
  },
  "Storage": {
    "Provider": "Local",
    "LocalBasePath": "../../../storage"
  },
  "_Storage_MinIO_Dev_Example": {
    "_comment": "MinIO ile local S3 storage kullanmak için Storage bloğunu aşağıdakiyle değiştir. Önce: docker compose up -d",
    "Provider": "S3",
    "S3BucketName": "xsltcraft",
    "S3Region": "us-east-1",
    "S3ServiceUrl": "http://localhost:9000",
    "S3AccessKey": "<.env'deki MINIO_ROOT_USER>",
    "S3SecretKey": "<.env'deki MINIO_ROOT_PASSWORD>"
  },
  "AllowedOrigins": [
    "http://localhost:5173"
  ]
}
